  },
  "engines": {
    "node": ">=20.18.1"
  },
  "dependencies": {
    "@openfn/language-common": "3.3.3"
  },
  "devDependencies": {
    "@openfn/compiler": "1.2.5",
    "@openfn/runtime": "1.9.3"
  }
}
