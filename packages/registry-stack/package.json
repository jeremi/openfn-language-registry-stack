{
  "name": "@openfn/language-registry-stack",
  "version": "0.1.0",
  "description": "OpenFn language helpers for Registry Stack services, starting with Registry Notary.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "jobs",
    "configuration-schema.json",
    "README.md"
